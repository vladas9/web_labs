---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import MobileStats from '../components/MobileStats.astro';
import Services from '../components/Services.astro';
import Builds from '../components/Builds.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Mascot from '../components/Mascot.astro';

const services = [
    {
        icon: '01',
        title: 'Custom Build Consultation',
        description: "Get expert advice on component selection tailored to your needs and budget. We'll help you choose the perfect parts for gaming, content creation, or professional work.",
    },
    {
        icon: '02',
        title: 'Professional Assembly',
        description: 'Expert assembly with cable management, thermal paste application, and BIOS configuration. Every build is tested for stability and performance.',
    },
    {
        icon: '03',
        title: 'Performance Testing',
        description: 'Comprehensive stress testing and benchmarking to ensure your system runs at peak performance with optimal temperatures.',
    },
    {
        icon: '04',
        title: 'Upgrades & Maintenance',
        description: 'Keep your system running smoothly with upgrade services, cleaning, thermal paste replacement, and performance optimization.',
    },
];

const builds = [
    {
        label: 'Gaming',
        title: 'Ultimate Gaming Rig',
        specs: ['RTX 4080 GPU', 'Intel i7-13700K', '32GB DDR5 RAM', '1TB NVMe SSD'],
        price: '$2,499',
    },
    {
        label: 'Creator',
        title: 'Content Creator Pro',
        specs: ['RTX 4070 Ti GPU', 'AMD Ryzen 9 7900X', '64GB DDR5 RAM', '2TB NVMe SSD'],
        price: '$2,899',
    },
    {
        label: 'Workstation',
        title: 'Professional Workstation',
        specs: ['RTX A4000 GPU', 'Intel Xeon W-2245', '128GB ECC RAM', '4TB NVMe SSD'],
        price: '$3,999',
    },
];

const aboutItems = [
    {
        title: 'Expert Consultation',
        description: 'Years of experience in PC building with up-to-date knowledge of the latest hardware and technologies.',
    },
    {
        title: 'Quality Components',
        description: 'We source parts from trusted manufacturers and ensure compatibility for optimal performance.',
    },
    {
        title: 'Warranty & Support',
        description: 'All builds come with warranty coverage and ongoing technical support for peace of mind.',
    },
    {
        title: 'Fast Turnaround',
        description: 'Most custom builds are completed within 3-5 business days with thorough testing.',
    },
];
---

<Layout title="Custom PC Build Service | Build Your Dream PC">
    <Header />
    <Hero
        title="Build Your Dream PC"
        subtitle="Expert custom PC building service for gamers, creators, and professionals. Get personalized recommendations, professional assembly, and ongoing support."
    />
    <MobileStats />
    <Services services={services} />
    <Builds builds={builds} />
    <About items={aboutItems} />
    <Contact />
    <Footer />
    <Mascot />

    <script>
        const hamburger = document.querySelector('.hamburger');
        const navMenu = document.querySelector('.nav-menu');
        const navLinks = document.querySelectorAll('.nav-link');

        hamburger?.addEventListener('click', () => {
            hamburger.classList.toggle('active');
            navMenu?.classList.toggle('active');
        });

        navLinks.forEach(link => {
            link.addEventListener('click', () => {
                hamburger?.classList.remove('active');
                navMenu?.classList.remove('active');
            });
        });
    </script>
</Layout>
