---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import MobileStats from '../components/MobileStats.astro';
import Services from '../components/Services.astro';
import Builds from '../components/Builds.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Mascot from '../components/Mascot.astro';

const [siteEntry] = await getCollection('site');
const s = siteEntry.data;

const servicesCollection = await getCollection('services');
const services = servicesCollection
    .sort((a, b) => a.data.order - b.data.order)
    .map((s) => ({
        icon: s.data.icon,
        title: s.data.title,
        description: s.data.description,
    }));

const buildsCollection = await getCollection('builds');
const builds = buildsCollection
    .sort((a, b) => a.data.order - b.data.order)
    .map((b) => ({
        label: b.data.label,
        title: b.data.title,
        specs: b.data.specs,
        price: b.data.price,
    }));

const aboutCollection = await getCollection('about');
const aboutItems = aboutCollection
    .sort((a, b) => a.data.order - b.data.order)
    .map((a) => ({
        title: a.data.title,
        description: a.data.description,
    }));
---

<Layout title="Custom PC Build Service | Build Your Dream PC">
    <Header logoText={s.logo_text} ctaText={s.header_cta_text} />
    <Hero
        title={s.hero_title}
        subtitle={s.hero_subtitle}
        primaryBtnText={s.hero_primary_btn_text}
        primaryBtnHref={s.hero_primary_btn_href}
        secondaryBtnText={s.hero_secondary_btn_text}
        secondaryBtnHref={s.hero_secondary_btn_href}
    />
    <MobileStats
        title={s.stats_title}
        stats={s.stats}
        ctaText={s.stats_cta_text}
        ctaHref={s.stats_cta_href}
    />
    <Services title={s.services_title} subtitle={s.services_subtitle} services={services} />
    <Builds title={s.builds_title} subtitle={s.builds_subtitle} builds={builds} />
    <About title={s.about_title} subtitle={s.about_subtitle} items={aboutItems} />
    <Contact title={s.contact_title} subtitle={s.contact_subtitle} />
    <Footer
        logoText={s.logo_text}
        tagline={s.site_tagline}
        email={s.footer_email}
        phone={s.footer_phone}
        hours={s.footer_hours}
        copyright={s.footer_copyright}
    />
    <Mascot />

    <script>
        const hamburger = document.querySelector('.hamburger');
        const navMenu = document.querySelector('.nav-menu');
        const navLinks = document.querySelectorAll('.nav-link');

        hamburger?.addEventListener('click', () => {
            hamburger.classList.toggle('active');
            navMenu?.classList.toggle('active');
        });

        navLinks.forEach(link => {
            link.addEventListener('click', () => {
                hamburger?.classList.remove('active');
                navMenu?.classList.remove('active');
            });
        });
    </script>
</Layout>
