---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Custom PC Build Service | Build Your Dream PC">
    <!-- Navigation -->
    <header class="header">
        <nav class="navbar">
            <div class="container">
                <div class="nav-wrapper">
                    <a href="#" class="logo">CustomPC</a>
                    <ul class="nav-menu">
                        <li><a href="#home" class="nav-link">Home</a></li>
                        <li><a href="#services" class="nav-link">Services</a></li>
                        <li><a href="#builds" class="nav-link">Builds</a></li>
                        <li><a href="#about" class="nav-link">About</a></li>
                        <li><a href="#contact" class="nav-link">Contact</a></li>
                    </ul>
                    <a href="#contact" class="btn btn-primary btn-nav">Get Started</a>
                    <button class="hamburger" aria-label="Toggle menu">
                        <span class="hamburger-line"></span>
                        <span class="hamburger-line"></span>
                        <span class="hamburger-line"></span>
                    </button>
                </div>
            </div>
        </nav>
    </header>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">Build Your Dream PC</h1>
                <p class="hero-subtitle">Expert custom PC building service for gamers, creators, and professionals. Get
                    personalized recommendations, professional assembly, and ongoing support.</p>
                <div class="hero-buttons">
                    <a href="#contact" class="btn btn-primary btn-large">Start Your Build</a>
                    <a href="#builds" class="btn btn-secondary btn-large">View Builds</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Mobile-Only Quick Stats Section -->
    <section class="mobile-only-section">
        <div class="container">
            <h2 class="mobile-only-title">Why Go Custom?</h2>
            <div class="mobile-stats">
                <div class="mobile-stat">
                    <span class="stat-number">500+</span>
                    <span class="stat-label">Builds Completed</span>
                </div>
                <div class="mobile-stat">
                    <span class="stat-number">99%</span>
                    <span class="stat-label">Client Satisfaction</span>
                </div>
                <div class="mobile-stat">
                    <span class="stat-number">3-5</span>
                    <span class="stat-label">Day Turnaround</span>
                </div>
            </div>
            <a href="#contact" class="btn btn-primary btn-large mobile-cta">Get Your Custom Build</a>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
        <div class="container">
            <h2 class="section-title">Our Services</h2>
            <p class="section-subtitle">Everything you need for your perfect custom PC</p>
            <div class="services-grid">
                <div class="service-card">
                    <div class="service-icon">01</div>
                    <h3>Custom Build Consultation</h3>
                    <p>Get expert advice on component selection tailored to your needs and budget. We'll help you choose
                        the perfect parts for gaming, content creation, or professional work.</p>
                </div>
                <div class="service-card">
                    <div class="service-icon">02</div>
                    <h3>Professional Assembly</h3>
                    <p>Expert assembly with cable management, thermal paste application, and BIOS configuration. Every
                        build is tested for stability and performance.</p>
                </div>
                <div class="service-card">
                    <div class="service-icon">03</div>
                    <h3>Performance Testing</h3>
                    <p>Comprehensive stress testing and benchmarking to ensure your system runs at peak performance with
                        optimal temperatures.</p>
                </div>
                <div class="service-card">
                    <div class="service-icon">04</div>
                    <h3>Upgrades & Maintenance</h3>
                    <p>Keep your system running smoothly with upgrade services, cleaning, thermal paste replacement, and
                        performance optimization.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Showcase Section -->
    <section id="builds" class="showcase">
        <div class="container">
            <h2 class="section-title">Featured Builds</h2>
            <p class="section-subtitle">Explore our carefully crafted custom PC configurations</p>
            <div class="builds-grid">
                <div class="build-card">
                    <div class="build-label">Gaming</div>
                    <h3>Ultimate Gaming Rig</h3>
                    <div class="build-specs">
                        <p>RTX 4080 GPU</p>
                        <p>Intel i7-13700K</p>
                        <p>32GB DDR5 RAM</p>
                        <p>1TB NVMe SSD</p>
                    </div>
                    <div class="build-price">From $2,499</div>
                    <a href="#contact" class="btn btn-primary">Configure</a>
                </div>
                <div class="build-card">
                    <div class="build-label">Creator</div>
                    <h3>Content Creator Pro</h3>
                    <div class="build-specs">
                        <p>RTX 4070 Ti GPU</p>
                        <p>AMD Ryzen 9 7900X</p>
                        <p>64GB DDR5 RAM</p>
                        <p>2TB NVMe SSD</p>
                    </div>
                    <div class="build-price">From $2,899</div>
                    <a href="#contact" class="btn btn-primary">Configure</a>
                </div>
                <div class="build-card">
                    <div class="build-label">Workstation</div>
                    <h3>Professional Workstation</h3>
                    <div class="build-specs">
                        <p>RTX A4000 GPU</p>
                        <p>Intel Xeon W-2245</p>
                        <p>128GB ECC RAM</p>
                        <p>4TB NVMe SSD</p>
                    </div>
                    <div class="build-price">From $3,999</div>
                    <a href="#contact" class="btn btn-primary">Configure</a>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about bg-light-bg py-20">
        <div class="container">
            <h2 class="section-title">Why Choose Us</h2>
            <p class="section-subtitle">Professional PC building with attention to every detail</p>
            <div class="about-grid mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
                <div class="about-item rounded-lg p-6 transition-all hover:shadow-lg">
                    <h3 class="text-primary font-bold mb-4 text-xl">Expert Consultation</h3>
                    <p class="text-gray-500 leading-relaxed">Years of experience in PC building with up-to-date
                        knowledge of the latest hardware and technologies.</p>
                </div>
                <div class="about-item rounded-lg p-6 transition-all hover:shadow-lg">
                    <h3 class="text-primary font-bold mb-4 text-xl">Quality Components</h3>
                    <p class="text-gray-500 leading-relaxed">We source parts from trusted manufacturers and ensure
                        compatibility for optimal performance.</p>
                </div>
                <div class="about-item rounded-lg p-6 transition-all hover:shadow-lg">
                    <h3 class="text-primary font-bold mb-4 text-xl">Warranty & Support</h3>
                    <p class="text-gray-500 leading-relaxed">All builds come with warranty coverage and ongoing
                        technical support for peace of mind.</p>
                </div>
                <div class="about-item rounded-lg p-6 transition-all hover:shadow-lg">
                    <h3 class="text-primary font-bold mb-4 text-xl">Fast Turnaround</h3>
                    <p class="text-gray-500 leading-relaxed">Most custom builds are completed within 3-5 business days
                        with thorough testing.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact bg-white py-20">
        <div class="container">
            <h2 class="section-title">Get Started Today</h2>
            <p class="section-subtitle">Tell us about your dream PC and we'll make it happen</p>
            <form class="contact-form max-w-2xl mx-auto mt-12">
                <div class="form-row grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div class="form-group flex flex-col">
                        <input type="text" placeholder="Your Name" required
                            class="px-4 py-3 border-2 border-gray-200 rounded-md text-base transition-all focus:outline-none focus:border-primary">
                    </div>
                    <div class="form-group flex flex-col">
                        <input type="email" placeholder="Your Email" required
                            class="px-4 py-3 border-2 border-gray-200 rounded-md text-base transition-all focus:outline-none focus:border-primary">
                    </div>
                </div>
                <div class="form-row grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div class="form-group flex flex-col">
                        <input type="tel" placeholder="Phone Number"
                            class="px-4 py-3 border-2 border-gray-200 rounded-md text-base transition-all focus:outline-none focus:border-primary">
                    </div>
                    <div class="form-group flex flex-col">
                        <select required
                            class="px-4 py-3 border-2 border-gray-200 rounded-md text-base transition-all focus:outline-none focus:border-primary">
                            <option value="">Select Build Type</option>
                            <option value="gaming">Gaming PC</option>
                            <option value="creator">Content Creation</option>
                            <option value="workstation">Workstation</option>
                            <option value="custom">Custom Build</option>
                        </select>
                    </div>
                </div>
                <div class="form-group flex flex-col">
                    <textarea placeholder="Tell us about your requirements, budget, and preferred components..."
                        rows="5" required
                        class="px-4 py-3 border-2 border-gray-200 rounded-md text-base transition-all focus:outline-none focus:border-primary resize-y min-h-[120px]"></textarea>
                </div>
                <button type="submit"
                    class="btn btn-primary btn-large w-full mt-4 cursor-pointer border-none">Send Request</button>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer bg-dark-bg text-text-light pt-12 pb-4">
        <div class="container">
            <div class="footer-content grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
                <div class="footer-section">
                    <h3 class="logo text-accent text-3xl font-bold mb-4">CustomPC</h3>
                    <p class="text-gray-400 leading-relaxed">Building dream PCs since 2020. Your trusted partner for
                        custom computer builds.</p>
                </div>
                <div class="footer-section">
                    <h4 class="text-text-light font-semibold text-lg mb-4">Quick Links</h4>
                    <ul class="footer-links space-y-2">
                        <li><a href="#home" class="text-gray-400 hover:text-accent transition-colors">Home</a></li>
                        <li><a href="#services" class="text-gray-400 hover:text-accent transition-colors">Services</a></li>
                        <li><a href="#builds" class="text-gray-400 hover:text-accent transition-colors">Builds</a></li>
                        <li><a href="#about" class="text-gray-400 hover:text-accent transition-colors">About</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4 class="text-text-light font-semibold text-lg mb-4">Contact Info</h4>
                    <p class="text-gray-400 leading-relaxed">Email: info@custompc.com</p>
                    <p class="text-gray-400 leading-relaxed">Phone: +1 (555) 123-4567</p>
                    <p class="text-gray-400 leading-relaxed">Hours: Mon-Fri 9AM-6PM</p>
                </div>
            </div>
            <div class="footer-bottom text-center pt-8 border-t border-white/10 text-gray-500">
                <p>&copy; 2026 CustomPC Build Service. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- Mascot -->
    <div class="mascot" id="mascot">
        <div class="mascot-tooltip">Hey there! Need help building your dream PC? Click "Get Started" above! 🖥️</div>
        <svg class="mascot-svg" viewBox="0 0 120 140" xmlns="http://www.w3.org/2000/svg">
            <rect x="25" y="45" width="70" height="55" rx="12" fill="#00d4ff" stroke="#1a1a2e" stroke-width="2" />
            <rect x="35" y="52" width="50" height="35" rx="5" fill="#1a1a2e" />
            <circle cx="50" cy="67" r="5" fill="#00d4ff" class="mascot-eye" />
            <circle cx="70" cy="67" r="5" fill="#00d4ff" class="mascot-eye" />
            <path d="M50 78 Q60 85 70 78" stroke="#00d4ff" stroke-width="2" fill="none" stroke-linecap="round" />
            <line x1="60" y1="45" x2="60" y2="28" stroke="#1a1a2e" stroke-width="3" stroke-linecap="round" />
            <circle cx="60" cy="24" r="6" fill="#ff6b35" class="mascot-antenna" />
            <rect x="10" y="55" width="15" height="8" rx="4" fill="#00d4ff" stroke="#1a1a2e" stroke-width="2" class="mascot-arm-left" />
            <rect x="95" y="55" width="15" height="8" rx="4" fill="#00d4ff" stroke="#1a1a2e" stroke-width="2" class="mascot-arm-right" />
            <rect x="35" y="100" width="14" height="18" rx="5" fill="#00d4ff" stroke="#1a1a2e" stroke-width="2" />
            <rect x="71" y="100" width="14" height="18" rx="5" fill="#00d4ff" stroke="#1a1a2e" stroke-width="2" />
            <rect x="30" y="115" width="24" height="10" rx="5" fill="#1a1a2e" />
            <rect x="66" y="115" width="24" height="10" rx="5" fill="#1a1a2e" />
            <circle cx="60" cy="92" r="4" fill="none" stroke="#1a1a2e" stroke-width="1.5" />
            <line x1="60" y1="88" x2="60" y2="91" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round" />
        </svg>
    </div>

    <script>
        const hamburger = document.querySelector('.hamburger');
        const navMenu = document.querySelector('.nav-menu');
        const navLinks = document.querySelectorAll('.nav-link');

        hamburger?.addEventListener('click', () => {
            hamburger.classList.toggle('active');
            navMenu?.classList.toggle('active');
        });

        navLinks.forEach(link => {
            link.addEventListener('click', () => {
                hamburger?.classList.remove('active');
                navMenu?.classList.remove('active');
            });
        });

        // Mascot: appear after 3 seconds
        const mascot = document.getElementById('mascot');
        setTimeout(() => {
            mascot?.classList.add('visible');
        }, 3000);

        // Close mascot tooltip when clicking elsewhere
        document.addEventListener('click', (e) => {
            if (mascot && !mascot.contains(e.target as Node)) {
                const tooltip = mascot.querySelector('.mascot-tooltip') as HTMLElement;
                if (tooltip) {
                    tooltip.style.opacity = '0';
                    tooltip.style.visibility = 'hidden';
                }
            }
        });
    </script>
</Layout>
