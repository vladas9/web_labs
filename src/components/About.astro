---
interface AboutItem {
    title: string;
    description: string;
}

interface Props {
    title?: string;
    subtitle?: string;
    items: AboutItem[];
}

const {
    title = 'Why Choose Us',
    subtitle = 'Professional PC building with attention to every detail',
    items,
} = Astro.props;
---

<section id="about" class="about bg-light-bg py-20">
    <div class="container">
        <h2 class="section-title">{title}</h2>
        <p class="section-subtitle">{subtitle}</p>
        <div class="about-grid mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
            {items.map(item => (
                <div class="about-item rounded-lg p-6 transition-all hover:shadow-lg">
                    <h3 class="text-primary font-bold mb-4 text-xl">{item.title}</h3>
                    <p class="text-gray-500 leading-relaxed">{item.description}</p>
                </div>
            ))}
        </div>
    </div>
</section>
