---
interface Props {
    logoText?: string;
    tagline?: string;
    email?: string;
    phone?: string;
    hours?: string;
    copyright?: string;
}

const {
    logoText = 'CustomPC',
    tagline = 'Building dream PCs since 2020. Your trusted partner for custom computer builds.',
    email = 'info@custompc.com',
    phone = '+1 (555) 123-4567',
    hours = 'Mon-Fri 9AM-6PM',
    copyright = '2026 CustomPC Build Service. All rights reserved.',
} = Astro.props;

const quickLinks = [
    { href: '#home', label: 'Home' },
    { href: '#services', label: 'Services' },
    { href: '#builds', label: 'Builds' },
    { href: '#about', label: 'About' },
];
---

<footer class="footer bg-dark-bg text-text-light pt-12 pb-4">
    <div class="container">
        <div class="footer-content grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
            <div class="footer-section">
                <h3 class="logo text-accent text-3xl font-bold mb-4">{logoText}</h3>
                <p class="text-gray-400 leading-relaxed">{tagline}</p>
            </div>
            <div class="footer-section">
                <h4 class="text-text-light font-semibold text-lg mb-4">Quick Links</h4>
                <ul class="footer-links space-y-2">
                    {quickLinks.map(link => (
                        <li><a href={link.href} class="text-gray-400 hover:text-accent transition-colors">{link.label}</a></li>
                    ))}
                </ul>
            </div>
            <div class="footer-section">
                <h4 class="text-text-light font-semibold text-lg mb-4">Contact Info</h4>
                <p class="text-gray-400 leading-relaxed">Email: {email}</p>
                <p class="text-gray-400 leading-relaxed">Phone: {phone}</p>
                <p class="text-gray-400 leading-relaxed">Hours: {hours}</p>
            </div>
        </div>
        <div class="footer-bottom text-center pt-8 border-t border-white/10 text-gray-500">
            <p>&copy; {copyright}</p>
        </div>
    </div>
</footer>
